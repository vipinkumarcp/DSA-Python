      "[1, 4, 9, 16, 25]\n"
     ]
    }
   ],
   "source": [
    "numbers = [1,2,3,4,5]\n",
    "\n",
    "nums = [i*i for i in numbers]\n",
    "\n",
    "print(nums )"
   ]
  }
